{
  "name": "@actalk/inkos-studio",
  "version": "1.6.2",
  "description": "InkOS Studio — Web workbench for novel writing",
  "type": "module",
  "main": "dist/api/index.js",
  "types": "dist/api/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Narcooo/inkos.git",
    "directory": "packages/studio"
  },
  "scripts": {
    "prepack": "pnpm run build && node ../../scripts/prepare-package-for-publish.mjs",
    "postpack": "node ../../scripts/restore-package-json.mjs",
    "prepublishOnly": "node ../../scripts/verify-no-workspace-protocol.mjs .",
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite --host --port 4567",
    "dev:server": "node scripts/dev-server.mjs",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "android:add": "cap add android",
    "android:runtime": "node scripts/prepare-android-node-runtime.mjs",
    "android:webp": "node scripts/convert-android-images-to-webp.mjs",
    "android:runtime:audit": "node scripts/audit-android-runtime-slim.mjs",
    "android:node24:use": "powershell -ExecutionPolicy Bypass -File scripts/use-custom-node24-lib.ps1",
    "android:sync": "pnpm run build:client && pnpm run android:runtime && cap sync android",
    "android:apk": "pnpm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:aab": "pnpm run android:sync && cd android && gradlew.bat bundleRelease",
    "preview": "vite preview",
    "pretypecheck": "pnpm --filter @actalk/inkos-core build",
    "test": "vitest run",
    "test:unit": "vitest run --exclude \"src/api/server.test.ts\"",
    "test:integration": "vitest run src/api/server.test.ts",
    "test:packaging": "vitest run --passWithNoTests \"src/**/publish-package.test.ts\"",
    "lint": "pnpm run typecheck",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@actalk/inkos-core": "workspace:*",
    "@base-ui/react": "^1.3.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource-variable/noto-serif-sc": "^5.2.10",
    "@fontsource/ma-shan-zheng": "^5.2.9",
    "@fontsource/zcool-kuaile": "^5.2.8",
    "@fontsource/zcool-qingke-huangyou": "^5.2.8",
    "@fontsource/zcool-xiaowei": "^5.2.8",
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.159",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "headroom-ai": "^0.22.4",
    "hono": "^4.12.25",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.2.0",
    "shiki": "^4.0.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.0",
    "cwebp-bin": "^8.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
