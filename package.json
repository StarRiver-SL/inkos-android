{
  "name": "inkos",
  "version": "1.4.8",
  "private": true,
  "description": "Autonomous AI novel writing CLI agent — 10-agent pipeline that writes, audits, and revises novels with continuity tracking",
  "keywords": [
    "ai-novel-writing",
    "ai-writing-agent",
    "novel-generator",
    "autonomous-writing",
    "litrpg",
    "progression-fantasy",
    "multi-agent",
    "creative-writing-ai",
    "openclaw-skill",
    "cli"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Narcooo/inkos"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r --if-present test:unit",
    "test:integration": "pnpm -r --if-present test:integration",
    "test:packaging": "pnpm -r --if-present test:packaging",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm typecheck && pnpm test:unit",
    "verify:publish-manifests": "node scripts/verify-no-workspace-protocol.mjs packages/core packages/cli packages/studio",
    "release": "pnpm typecheck && pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs",
      "msw"
    ],
    "overrides": {
      "@mariozechner/pi-ai": "0.67.1",
      "@mariozechner/pi-agent-core": "0.67.1"
    }
  }
}
